{
  "outputDirectory": "preview",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/cron/epoch-tick.js": { "maxDuration": 60 },
    "api/epoch.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
