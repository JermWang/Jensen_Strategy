{
  "outputDirectory": "preview",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/epoch",
      "schedule": "* * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
